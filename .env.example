# ---- Telegram (required) ----
# Create a bot with @BotFather -> /newbot, paste the token here.
TELEGRAM_BOT_TOKEN=123456789:AAEXAMPLE-token-from-botfather
# Your numeric chat id. Message your bot once, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id":...}.
# A negative id is a group/channel; a positive id is a private chat.
TELEGRAM_CHAT_ID=123456789

# ---- Fetcher selection ----
# apify     -> uses the hosted gaspedaal scraper (reliable on a VPS/datacenter IP, paid)
# playwright -> free headless Chrome (needs a residential proxy on a datacenter IP)
FETCHER=apify

# ---- Apify (required when FETCHER=apify) ----
# Get a token at https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxx
#
# Two supported actors:
#   unfenced-group/gaspedaal-nl-scraper        (default) pay-per-result
#       (~$1.50 / 1,000 results), FREE built-in WAF bypass -> keep proxy off.
#   stealth_mode/gaspedaal-cars-search-scraper flat $20/mo rental; set
#       APIFY_USE_PROXY=true so it uses Apify's residential proxy.
APIFY_ACTOR_ID=unfenced-group/gaspedaal-nl-scraper
# Leave false for unfenced-group (its bypass is free). Set true for stealth_mode.
APIFY_USE_PROXY=false

# ---- Playwright (used when FETCHER=playwright) ----
# Gaspedaal is behind Akamai/DPG WAF. From a datacenter IP you almost certainly
# need a residential/mobile proxy here, e.g. http://user:pass@host:port
PLAYWRIGHT_PROXY=
PLAYWRIGHT_HEADLESS=true

# ---- Polling ----
POLL_INTERVAL_SECONDS=300
POLL_JITTER_SECONDS=60
MAX_ITEMS_PER_SEARCH=25

# On the very first poll of a new search, seed already-listed cars silently
# instead of sending a burst of notifications. Set true to be notified about all
# current matches on first run.
NOTIFY_ON_FIRST_RUN=false

# Send a short "started" / "error" status message to Telegram.
SEND_STATUS_MESSAGES=true

# ---- Paths ----
CONFIG_PATH=config.yaml
DB_PATH=data/seen.sqlite3

LOG_LEVEL=INFO
